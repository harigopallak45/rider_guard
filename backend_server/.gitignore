# ──────────────────────────────────────────────
# Express Backend — backend_server/.gitignore
# ──────────────────────────────────────────────

# Dependencies
node_modules/

# Environment secrets — NEVER commit these
.env
.env.local
.env.production
.env.staging
*.pem
serviceAccountKey.json
firebase-adminsdk*.json

# Build / dist
dist/
build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Cache
.npm
.eslintcache
.node_repl_history

# OS
.DS_Store
Thumbs.db
